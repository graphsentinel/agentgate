# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
.mypy_cache/
.ruff_cache/
.pytest_cache/
.coverage
htmlcov/

# DriftWatch runtime state (bind-mounted, never source).
# Root-level sqlite baseline store (working-dir relative, db/sqlite.py):
/data/
# Demo neo4j volume etc. — ignore the *contents* but keep the dir (.gitkeep tracked).
# (Can't re-include a file under an ignored dir, so ignore contents, not the dir.)
examples/k3d-cluster-demo/data/*
!examples/k3d-cluster-demo/data/.gitkeep

# Evaluation outputs (archival, regenerated by `make eval`)
/evaluation/results/

# OS / editor
.DS_Store
*.swp
.idea/
.vscode/
VISION.md

# Internal design docs — kept local, not published. User-facing docs live in "Docs/User Manuals/".
Docs/design/
