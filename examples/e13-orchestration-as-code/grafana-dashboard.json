{
  "uid": "agentgate",
  "title": "AgentGate — runs & governance",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "timezone": "browser",
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Agent runs (total)",
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" } }, "overrides": [] },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(agentgate_decisions_total)" }
      ]
    },
    {
      "id": 2,
      "type": "piechart",
      "title": "Runs by gate action (log = clean, block = gated)",
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": { "legend": { "displayMode": "table", "placement": "right", "values": ["value"] } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (gate_action) (agentgate_decisions_total)", "legendFormat": "{{gate_action}}" }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Delegation violations",
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [
            { "color": "green", "value": null }, { "color": "red", "value": 1 } ] }
        }, "overrides": []
      },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (anomaly_kind) (agentgate_anomaly_total)", "legendFormat": "{{anomaly_kind}}" }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Agent runs / sec (by gate action)",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 15 } }, "overrides": [] },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (gate_action) (rate(agentgate_decisions_total[1m]))",
          "legendFormat": "{{gate_action}}" }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Delegation violations / sec",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "bars", "fillOpacity": 40 } }, "overrides": [] },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (anomaly_kind) (rate(agentgate_anomaly_total[1m]))",
          "legendFormat": "{{anomaly_kind}}" }
      ]
    }
  ]
}
